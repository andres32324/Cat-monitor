<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐱"
        android:textSize="72sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cat Monitor"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el modo para este teléfono"
        android:textSize="14sp"
        android:textColor="#AAAACC"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnServer"
        android:layout_width="280dp"
        android:layout_height="80dp"
        android:text="📡  MODO GATO\n(Teléfono junto al gato)"
        android:textSize="14sp"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnClient"
        android:layout_width="280dp"
        android:layout_height="80dp"
        android:text="🎧  MODO ESCUCHA\n(Tu teléfono)"
        android:textSize="14sp"
        android:backgroundTint="#0F3460"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ambos teléfonos deben estar en la misma red WiFi"
        android:textSize="12sp"
        android:textColor="#666688"
        android:gravity="center"
        android:layout_marginTop="48dp"/>

</LinearLayout>
