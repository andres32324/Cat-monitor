<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡"
        android:textSize="48sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MODO GATO"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- Preview local de la cámara -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="8dp"/>

    <!-- Botón cambiar cámara -->
    <Button
        android:id="@+id/btnSwitchCamera"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="📷 Frontal"
        android:textSize="13sp"
        android:backgroundTint="#333355"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- IP Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F3460"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresa esta IP en el cliente:"
            android:textSize="12sp"
            android:textColor="#AAAACC"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Obteniendo IP..."
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#E94560"/>
    </LinearLayout>

    <!-- Estado -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Presiona Iniciar para comenzar"
        android:textSize="14sp"
        android:textColor="#CCCCFF"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:minHeight="40dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="▶ Iniciar"
        android:textSize="16sp"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"/>

</LinearLayout>
