<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📡"
        android:textSize="64sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MODO GATO"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <!-- Cuadro con la IP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F3460"
        android:padding="20dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Muestra esta dirección al otro teléfono:"
            android:textSize="13sp"
            android:textColor="#AAAACC"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Obteniendo IP..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E94560"/>
    </LinearLayout>

    <!-- Estado -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Presiona Iniciar para comenzar"
        android:textSize="15sp"
        android:textColor="#CCCCFF"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:minHeight="60dp"/>

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="▶ Iniciar"
        android:textSize="18sp"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"/>

</LinearLayout>
